# Piramyd API Key — required for most tools (chat, images, audio, video, music, moderation)
PIRAMYD_API_KEY=your-api-key-here

# Piramyd JWT Token — required only for management tools (api key management, usage stats, subscription)
PIRAMYD_JWT_TOKEN=your-jwt-token-here

# Base URL for the Piramyd API (default: https://api.piramyd.cloud)
PIRAMYD_API_BASE_URL=https://api.piramyd.cloud

# Port for HTTP/SSE transport mode (default: 3000)
PORT=3000
